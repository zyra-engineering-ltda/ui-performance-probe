{
  "manifest_version": 3,
  "name": "Frontend Performance Probe",
  "version": "1.0.0",
  "description": "JavaScript UI performance diagnostics tool.",
  "icons": {
    "16": "static/img/favicon-16x16.png",
    "48": "static/img/android-icon-48x48.png",
    "128": "static/img/apple-icon-180.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}